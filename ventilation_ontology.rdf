<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://www.example.org/ventilation"
         xmlns="http://www.example.org/ventilation#">

<owl:Ontology rdf:about="http://www.example.org/ventilation"/>

<owl:ObjectProperty rdf:about="#hasSensor">
  <rdfs:domain rdf:resource="#Workshop"/>
  <rdfs:range rdf:resource="#Sensor"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasActuator">
  <rdfs:domain rdf:resource="#VentilationSystem"/>
  <rdfs:range rdf:resource="#Actuator"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasRule">
  <rdfs:domain rdf:resource="#VentilationSystem"/>
  <rdfs:range rdf:resource="#Rule"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#monitors">
  <rdfs:domain rdf:resource="#Sensor"/>
  <rdfs:range rdf:resource="#EnvironmentalCondition"/>
</owl:ObjectProperty>

<owl:DatatypeProperty rdf:about="#hasTemperature">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#Sensor"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#hasHumidity">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#Sensor"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#hasCO2">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#Sensor"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#hasAirflow">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#Actuator"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#hasPriority">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#Rule"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#hasFanSpeed">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#VentilationSystem"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#hasHeaterPower">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#VentilationSystem"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#hasCoolerPower">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#VentilationSystem"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#hasHumidifierPower">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#VentilationSystem"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:Class rdf:about="#Workshop">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#VentilationSystem">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Sensor">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Actuator">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Rule">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#EnvironmentalCondition">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:NamedIndividual rdf:about="#MainWorkshop">
  <rdf:type rdf:resource="#Workshop"/>
  <hasSensor rdf:resource="#TemperatureSensor"/>
  <hasSensor rdf:resource="#HumiditySensor"/>
  <hasSensor rdf:resource="#CO2Sensor"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#MainVentilation">
  <rdf:type rdf:resource="#VentilationSystem"/>
  <hasFanSpeed rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0.0</hasFanSpeed>
  <hasHeaterPower rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">100.0</hasHeaterPower>
  <hasCoolerPower rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0.0</hasCoolerPower>
  <hasHumidifierPower rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0.0</hasHumidifierPower>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#TemperatureSensor">
  <rdf:type rdf:resource="#Sensor"/>
  <hasTemperature rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">22.363998977343257</hasTemperature>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#HumiditySensor">
  <rdf:type rdf:resource="#Sensor"/>
  <hasHumidity rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">50.0</hasHumidity>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#CO2Sensor">
  <rdf:type rdf:resource="#Sensor"/>
  <hasCO2 rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">400.0</hasCO2>
</owl:NamedIndividual>


</rdf:RDF>
